# Copy to .env and fill in values — never commit .env

# LinkedIn API (https://www.linkedin.com/developers/apps)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# Your numeric LinkedIn member ID (find it: LinkedIn → Me → View Profile → browser Dev Tools → Network → any api.linkedin.com call → look for "id" field)
LINKEDIN_MEMBER_ID=

# PyPI (already saved to ~/.pypirc — only needed here if not using .pypirc)
# PYPI_TOKEN=
